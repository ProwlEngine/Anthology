    <ItemGroup>
        <ProjectReference Include="..\..\Vector\Vector\Vector.csproj" />
        <ProjectReference Include="..\Graphite\Prowl.Graphite.csproj" />
    </ItemGroup>

    <ItemGroup>
        <InternalsVisibleTo Include="Prowl.Graphite.ShaderDef.Tests" />
        <InternalsVisibleTo Include="Prowl.Graphite.ShaderDef.Compiler" />
        <InternalsVisibleTo Include="Prowl.Graphite.ShaderDef.Compiler.Tests" />
    </ItemGroup>
</Project>
