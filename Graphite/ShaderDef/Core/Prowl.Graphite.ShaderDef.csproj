        <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
        <OutputType>Library</OutputType>
    </PropertyGroup>

    <PropertyGroup>
        <PackageId>Prowl.Graphite.ShaderDef</PackageId>
        <Description>The ShaderDef language spec and variant runtime for Prowl.Graphite.</Description>
